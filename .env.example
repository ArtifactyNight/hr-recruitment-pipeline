# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hr_pipeline

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth + Calendar 
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# Required scopes: email, profile, https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Generative AI (Gemini)
# https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Apify API Token
# https://console.apify.com/
APIFY_API_TOKEN=

# Cloudflare R2 (PDF resume storage)
# Required for PDF resume uploads. Text-only resumes still work without this.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
